{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "jsx": "react-jsx",
    "noUncheckedIndexedAccess": true,
    "outDir": "./dist",
    "paths": {
      "@pedi/chika-types": ["../types/src"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
