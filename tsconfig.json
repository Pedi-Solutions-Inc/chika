{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@pedi/chika-types": ["./packages/types/src"],
      "@pedi/chika-sdk": ["./packages/sdk/src"]
    }
  },
  "include": ["packages/*/src/**/*.ts"]
}
