# =============================================================================
# Chika Server Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Required variables are uncommented. Optional variables are commented out.
# =============================================================================

# --- Server ---

# Port the HTTP server listens on.
# Default: 3000
PORT=3000

# Runtime environment. Controls Sentry sample rates and error verbosity.
# Allowed: development | production | test
# Default: development
NODE_ENV=development

# --- MongoDB ---

# MongoDB connection string. Required.
# For local development: mongodb://localhost:27017
# For Atlas: mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_URI=mongodb://localhost:27017

# MongoDB database name.
# Default: chika
MONGODB_DB=chika

# --- Authentication ---

# Shared secret for internal API endpoints (/internal/channels/*).
# Used by your backend services to send system messages and close channels.
# Must be passed as the X-Api-Key header. Required.
API_KEY=your-api-key-here

# --- Observability ---

# Sentry DSN for error tracking and performance monitoring.
# Omit or leave empty to disable Sentry entirely.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
